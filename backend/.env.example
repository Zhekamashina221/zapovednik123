# Server
PORT=3001
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
# JWT_REFRESH_SECRET=
SALT_ROUNDS=10
CORS_ORIGIN=http://localhost:5173

# OpenRouteService (маршруты на карте)
# https://openrouteservice.org/dev/#/signup
ORS_API_KEY=
ORS_SNAP_RADIUS_METERS=1000

# Почта (Gmail: 2FA + App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Zapovednik <your-test@gmail.com>"
APP_PUBLIC_URL=http://localhost:5173
EMAIL_VERIFY_EXPIRES_HOURS=48
PASSWORD_RESET_EXPIRES_HOURS=1
EMAIL_RESEND_COOLDOWN_SEC=120

# Оформление писем
MAIL_APP_NAME=Zapovednik
MAIL_BRAND_COLOR=#2e8b57
MAIL_BRAND_COLOR_DARK=#247a4c

