@startuml activity_zapovednik_simple
skinparam shadowing false
skinparam ActivityBackgroundColor #F8F9FA
skinparam ActivityBorderColor #333333
skinparam defaultFontSize 12

title Диаграмма деятельности — работа приложения Zapovednik

start
:Запуск веб-приложения\nв браузере;
:Ввод e-mail и пароля\n(при необходимости);
:Нажатие «Войти»;
:Аутентификация (JWT);

if (Данные верны?) then (нет)
  :Сообщение об ошибке;
  stop
else (да)
endif

if (Роль пользователя?) then (гость)
  :Просмотр каталога и карты ООПТ\nбез персональных функций;
elseif (пользователь) then
  :Доступ к избранному,\nотзывам, профилю,\nсохранению маршрутов;
else (администратор)
  :Доступ ко всем функциям\nпользователя;
endif

repeat
  :Выбор раздела\nв главном меню;

  if (Раздел?) then (Каталог / карта)
    :Просмотр списка и карты,\nпоиск и фильтрация;
    :Просмотр карточки ООПТ;
    if (Действие?) then (Маршрут)
      :Построение маршрута\n(ORS или внешний навигатор);
    elseif (Избранное) then
      :Добавление или удаление\nиз избранного;
    elseif (Отзыв) then
      :Оставление отзыва;
    else (Просмотр)
    endif

  elseif (Подборки маршрутов) then
    :Просмотр подборок\nи деталей маршрута;

  elseif (Профиль) then
    :Просмотр избранного\nи сохранённых маршрутов;
    :Изменение профиля;

  elseif (Админ-панель) then
    if (Роль admin?) then (нет)
      :Отказ в доступе;
    else (да)
      :Управление ООПТ, пользователями,\nотзывами, подборками;
    endif

  elseif (Вход / регистрация) then
    :Регистрация или вход\nв систему;

  elseif (Выход) then
    stop
  else (Главная)
    :Интерактивная карта\nна главной странице;
  endif

  :Сохранение данных в БД SQLite,\nпри необходимости — запись\nв журнал аудита;

repeat while (Продолжить работу?) is (да)
->нет;

stop

@enduml
