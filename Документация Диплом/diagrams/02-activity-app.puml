@startuml activity_zapovednik_full
skinparam shadowing false
skinparam ActivityBackgroundColor #F8F9FA
skinparam ActivityBorderColor #333333
skinparam defaultFontSize 11

title Диаграмма деятельности — работа приложения Zapovednik (общая)

|Пользователь|
start
:Запуск веб-приложения\nв браузере;

|Клиент (Vue 3 + Vue Router)|
:Загрузка главной страницы\n(HomeView);
:Инициализация Pinia,\nпроверка токена в localStorage;

|Сервер (Express API)|
if (Токен сохранён?) then (да)
  :GET /api/profile\n(проверка JWT);
  |Клиент (Vue 3 + Vue Router)|
  if (Токен действителен?) then (да)
    :Восстановление сессии\n(AuthStore);
  else (нет)
    :Очистка сессии;
  endif
else (нет)
  |Клиент (Vue 3 + Vue Router)|
  :Режим гостя;
endif

|Пользователь|
repeat
  :Выбор раздела\nв главном меню;

  |Клиент (Vue 3 + Vue Router)|
  if (Раздел?) then (Каталог / карта)
    :Переход на /list;
    |Сервер (Express API)|
    :GET /api/reserves\n(фильтры, пагинация);
    |База данных SQLite|
    :Выборка из reserves,\nphotos (при необходимости);
    |Клиент (Vue 3 + Vue Router)|
    :Отображение списка\nи карты Leaflet\n(кластеризация маркеров);
    |Пользователь|
    :Поиск, фильтры\n(тип, область, район);
    :Выбор ООПТ;
    |Клиент (Vue 3 + Vue Router)|
    :Переход на /reserve/:id;
    |Сервер (Express API)|
    :GET /api/reserves/:id;
    |Клиент (Vue 3 + Vue Router)|
    :Карточка ООПТ\n(галерея, описание, карта);
    if (Действие на карточке?) then (Маршрут)
      |Пользователь|
      :Построение маршрута;
      |Клиент (Vue 3 + Vue Router)|
      if (Способ старта?) then (геолокация / карта)
        |Сервер (Express API)|
        :POST /api/routing;
        :OpenRouteService;
        |Клиент (Vue 3 + Vue Router)|
        :Линия маршрута на карте;
      else (внешний навигатор)
        :Открытие ссылки\nвнешнего сервиса;
      endif
    elseif (Избранное) then
      if (Авторизован?) then (нет)
        :Переход на /login;
      else (да)
        |Сервер (Express API)|
        :POST или DELETE\n/api/favorites;
        |База данных SQLite|
        :Таблица favorites;
      endif
    elseif (Отзыв) then
      if (Авторизован?) then (нет)
        :Переход на /login;
      else (да)
        |Пользователь|
        :Оценка и комментарий;
        |Сервер (Express API)|
        :POST /api/reviews;
        |База данных SQLite|
        :Таблица reviews;
      endif
    else (Просмотр)
    endif

  elseif (Маршруты) then
    :Переход на /marshruty;
    |Сервер (Express API)|
    :GET /api/curated-routes;
    |Клиент (Vue 3 + Vue Router)|
    :Список подборок;
    |Пользователь|
    :Выбор подборки;
    :Переход на /marshruty/:slug;
    |Клиент (Vue 3 + Vue Router)|
    :Детали подборки\nи карта маршрута;

  elseif (Вход / регистрация) then
    :Переход на /login;
    |Пользователь|
    if (Уже есть аккаунт?) then (да)
      :Ввод email и пароля;
      |Сервер (Express API)|
      :POST /api/auth/login;
      |База данных SQLite|
      :Проверка users,\nзапись refresh_tokens;
    else (нет)
      :Регистрация\n(email, пароль, имя);
      |Сервер (Express API)|
      :POST /api/auth/register;
      |База данных SQLite|
      :INSERT users;
    endif
    |Клиент (Vue 3 + Vue Router)|
    :Сохранение JWT,\nперенаправление;

  elseif (Профиль) then
    if (Авторизован?) then (нет)
      :Переход на /login;
    else (да)
      :Переход на /profile\n(meta: requiresAuth);
      |Сервер (Express API)|
      :GET избранное,\nсохранённые маршруты;
      |Клиент (Vue 3 + Vue Router)|
      :Профиль пользователя;
      |Пользователь|
      :Просмотр избранного\nи маршрутов;
      :Выход из системы;
      |Сервер (Express API)|
      :Отзыв refresh-токена;
      |Клиент (Vue 3 + Vue Router)|
      :Очистка AuthStore;
    endif

  elseif (Админ-панель) then
    if (Роль admin?) then (нет)
      :Отказ доступа,\nредирект на /;
    else (да)
      :Переход на /admin\n(meta: requiresAdmin);
      |Пользователь|
      :Работа в разделах:\nООПТ, пользователи,\nотзывы, подборки, аудит;
      |Сервер (Express API)|
      :CRUD /api/admin/*;
      |База данных SQLite|
      :Изменение данных,\nзапись admin_audit_logs;
    endif

  else (Главная)
    :Остаётся на HomeView;
  endif

  |Пользователь|
repeat while (Продолжить работу?) is (да)
->нет;

|Клиент (Vue 3 + Vue Router)|
:Закрытие вкладки\nили выход;

stop

@enduml
