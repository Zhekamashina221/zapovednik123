@startuml use_case_zapovednik
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam shadowing false

title Диаграмма вариантов использования — портал Zapovednik

actor "Гость" as Guest
actor "Авторизованный\nпользователь" as User
actor "Администратор" as Admin

rectangle "Геоинформационный портал Zapovednik" {

  package "Просмотр каталога" {
    usecase "Просмотр списка ООПТ" as UC_List
    usecase "Просмотр карты\nс кластеризацией" as UC_Map
    usecase "Поиск и фильтрация" as UC_Filter
    usecase "Просмотр карточки ООПТ" as UC_Card
    usecase "Просмотр подборок\nмаршрутов" as UC_Curated
  }

  package "Маршрутизация" {
    usecase "Построение маршрута\nдо объекта" as UC_Route
    usecase "Сохранение маршрута" as UC_SaveRoute
  }

  package "Учётная запись" {
    usecase "Регистрация" as UC_Reg
    usecase "Вход в систему" as UC_Login
    usecase "Выход из системы" as UC_Logout
  }

  package "Персональные данные" {
    usecase "Управление избранным" as UC_Fav
    usecase "Просмотр профиля" as UC_Profile
    usecase "Оставление отзыва" as UC_Review
  }

  package "Администрирование" {
    usecase "Управление ООПТ" as UC_AdminRes
    usecase "Управление пользователями" as UC_AdminUsers
    usecase "Модерация отзывов" as UC_AdminRev
    usecase "Управление подборками\nмаршрутов" as UC_AdminRoutes
    usecase "Просмотр аналитики\nи журнала аудита" as UC_AdminAudit
  }
}

Guest --> UC_List
Guest --> UC_Map
Guest --> UC_Filter
Guest --> UC_Card
Guest --> UC_Curated
Guest --> UC_Route
Guest --> UC_Reg
Guest --> UC_Login

User --|> Guest
User --> UC_Fav
User --> UC_Profile
User --> UC_Review
User --> UC_SaveRoute
User --> UC_Logout

Admin --> UC_Login
Admin --> UC_AdminRes
Admin --> UC_AdminUsers
Admin --> UC_AdminRev
Admin --> UC_AdminRoutes
Admin --> UC_AdminAudit

UC_Card ..> UC_Filter : <<include>>
UC_Route ..> UC_Card : <<include>>
UC_Fav ..> UC_Login : <<include>>
UC_Review ..> UC_Login : <<include>>
UC_SaveRoute ..> UC_Login : <<include>>
UC_SaveRoute ..> UC_Route : <<extend>>
UC_AdminRes ..> UC_Login : <<include>>

@enduml
