@startuml use_case_zapovednik_v2
skinparam shadowing false
skinparam packageStyle folder
skinparam actorStyle awesome
skinparam defaultFontSize 11
skinparam nodesep 30
skinparam ranksep 28

title Диаграмма вариантов использования — портал Zapovednik

' Актёры по иерархии (как у одногруппника: базовый → расширенный → администратор)
actor "Гость" as Guest
actor "Авторизованный\nпользователь" as User
actor "Администратор" as Admin

Guest <|-- User
User <|-- Admin

' Отдельные прецеденты вне пакетов
usecase "Вход в систему" as UC_Login
usecase "Выход из системы" as UC_Logout
usecase "Просмотр дашборда" as UC_Dashboard

' --- Пакеты с прецедентами ---

package "Просмотр каталога" as P_Catalog {
  usecase "Просмотр списка" as UC_List
  usecase "Просмотр карты" as UC_Map
  usecase "Поиск и фильтрация" as UC_Filter
  usecase "Просмотр карточки" as UC_Card
}

package "Маршрутизация" as P_Route {
  usecase "Просмотр подборок" as UC_Curated
  usecase "Построение маршрута" as UC_Route
  usecase "Сохранение маршрута" as UC_SaveRoute
}

package "Учётная запись" as P_Account {
  usecase "Регистрация" as UC_Reg
  usecase "Подтверждение e-mail" as UC_Verify
  usecase "Восстановление пароля" as UC_ResetPwd
}

package "Личный кабинет" as P_Profile {
  usecase "Просмотр профиля" as UC_ProfileView
  usecase "Редактирование профиля" as UC_ProfileEdit
  usecase "Управление избранным" as UC_Fav
  usecase "Оставление отзыва" as UC_Review
}

package "Администрирование" as P_Admin {
  usecase "Управление ООПТ" as UC_AdminRes
  usecase "Управление фотографиями" as UC_AdminPhoto
  usecase "Управление пользователями" as UC_AdminUsers
  usecase "Модерация отзывов" as UC_AdminRev
  usecase "Управление подборками" as UC_AdminRoutes
  usecase "Журнал аудита" as UC_Audit
}

' --- Связи актёров (гость) ---
Guest --> UC_Login
Guest --> UC_Reg
Guest --> UC_List
Guest --> UC_Map
Guest --> UC_Filter
Guest --> UC_Card
Guest --> UC_Curated
Guest --> UC_Route
Guest --> UC_ResetPwd

' --- Авторизованный пользователь ---
User --> UC_Logout
User --> UC_Verify
User --> UC_ProfileView
User --> UC_ProfileEdit
User --> UC_Fav
User --> UC_Review
User --> UC_SaveRoute

' --- Администратор ---
Admin --> UC_Dashboard
Admin --> UC_AdminRes
Admin --> UC_AdminPhoto
Admin --> UC_AdminUsers
Admin --> UC_AdminRev
Admin --> UC_AdminRoutes
Admin --> UC_Audit

' --- Раскладка: актёры в центре, пакеты вокруг ---
P_Catalog -[hidden]up- Guest
P_Route -[hidden]left- Guest
P_Profile -[hidden]down- User
P_Account -[hidden]down- Guest
P_Admin -[hidden]right- Admin

UC_Login -[hidden]left- Guest
UC_Logout -[hidden]right- User
UC_Dashboard -[hidden]up- Admin

@enduml
