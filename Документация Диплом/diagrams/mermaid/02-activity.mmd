%%{init: {'theme': 'base', 'flowchart': {'curve': 'basis'}}}%%
flowchart TD
    Start([Начало]) --> OpenCard["Открытие карточки ООПТ"]

    subgraph Client["Клиент Vue 3"]
        OpenCard --> ShowCard["Отображение карточки"]
        ShowCard --> AuthCheck1{Авторизован?}
        AuthCheck1 -->|да| ShowFav["Кнопка избранного<br/>и блок отзывов"]
        AuthCheck1 -->|нет| ViewOnly["Только просмотр"]
        ShowFav --> FavClick["Нажатие «В избранное»"]
        ViewOnly --> FavClick
        FavClick --> AuthCheck2{Авторизован?}
        AuthCheck2 -->|нет| GoLogin["Переход на /login"]
        GoLogin --> End1([Конец])
        AuthCheck2 -->|да| RouteReq["Запрос построения маршрута"]
        RouteReq --> RouteMode{Способ старта?}
        RouteMode -->|геолокация| Geo["Geolocation API"]
        RouteMode -->|карта| Pick["Точка на карте Leaflet"]
        RouteMode -->|навигатор| Ext["Внешний навигатор"]
        Ext --> End2([Конец])
        Geo --> DrawRoute["Отрисовка GeoJSON<br/>длина и время"]
        Pick --> DrawRoute
        DrawRoute --> SaveQ{Сохранить маршрут?}
        SaveQ -->|да| Saved["Маршрут в профиле"]
        SaveQ -->|нет| End3([Конец])
        Saved --> End3
    end

    subgraph Server["Сервер Express"]
        OpenCard --> GET1["GET /api/reserves/:id"]
        AuthCheck1 -->|да| GET2["JWT + избранное + отзывы"]
        AuthCheck2 -->|да| FavAPI["POST/DELETE /api/favorites"]
        Geo --> RouteAPI["POST /api/routing"]
        Pick --> RouteAPI
        RouteAPI --> ORS["OpenRouteService"]
        SaveQ -->|да| SaveAPI["POST /api/saved-routes"]
    end

    subgraph DB["SQLite"]
        GET1 --> T1[("reserves, photos")]
        FavAPI --> T2[("favorites")]
        SaveAPI --> T3[("user_saved_routes")]
    end

    GET1 --> ShowCard
    GET2 --> ShowFav
    FavAPI --> ShowFav
    ORS --> DrawRoute
