%%{init: {'theme': 'base', 'flowchart': {'curve': 'basis'}}}%%
flowchart TD
    Start([Запуск приложения]) --> Home["Главная HomeView"]
    Home --> Init["Pinia + проверка токена"]

    Init --> HasToken{Токен в localStorage?}
    HasToken -->|да| ProfileAPI["GET /api/profile"]
    HasToken -->|нет| GuestMode["Режим гостя"]
    ProfileAPI --> ValidJWT{JWT действителен?}
    ValidJWT -->|да| Session["Восстановление AuthStore"]
    ValidJWT -->|нет| Clear["Очистка сессии"]
    Session --> Menu
    Clear --> Menu
    GuestMode --> Menu

    Menu{Выбор раздела меню}

    Menu -->|Каталог| List["/list — список и карта"]
    List --> APIList["GET /api/reserves"]
    APIList --> Filters["Поиск и фильтры"]
    Filters --> PickReserve["Выбор ООПТ"]
    PickReserve --> Card["/reserve/:id — карточка"]
    Card --> CardAction{Действие?}

    CardAction -->|Маршрут| RouteFlow["Построение маршрута<br/>ORS / навигатор"]
    CardAction -->|Избранное| FavFlow{Авторизован?}
    FavFlow -->|нет| LoginRedirect["/login"]
    FavFlow -->|да| FavAPI["favorites API"]
    CardAction -->|Отзыв| RevFlow{Авторизован?}
    RevFlow -->|нет| LoginRedirect
    RevFlow -->|да| RevAPI["POST /api/reviews"]
    CardAction -->|Просмотр| Menu

    Menu -->|Маршруты| CurList["/marshruty"]
    CurList --> CurAPI["GET curated-routes"]
    CurAPI --> CurDetail["/marshruty/:slug"]
    CurDetail --> Menu

    Menu -->|Вход| LoginPage["/login"]
    LoginPage --> AuthType{Аккаунт есть?}
    AuthType -->|да| Login["POST /auth/login"]
    AuthType -->|нет| Register["POST /auth/register"]
    Login --> JWT["Сохранение JWT"]
    Register --> JWT
    JWT --> Menu

    Menu -->|Профиль| ProfCheck{Авторизован?}
    ProfCheck -->|нет| LoginRedirect
    ProfCheck -->|да| Profile["/profile — избранное,<br/>сохранённые маршруты"]
    Profile --> Logout["Выход, отзыв токена"]
    Logout --> Menu

    Menu -->|Админ| AdminCheck{role = admin?}
    AdminCheck -->|нет| Deny["Редирект на /"]
    AdminCheck -->|да| Admin["/admin — ООПТ, пользователи,<br/>отзывы, подборки, аудит"]
    Admin --> AdminAPI["CRUD /api/admin/*<br/>admin_audit_logs"]
    AdminAPI --> Menu

    Deny --> Menu
    RouteFlow --> Menu
    FavAPI --> Menu
    RevAPI --> Menu
    LoginRedirect --> LoginPage

    Menu -->|Выход из приложения| Stop([Закрытие вкладки])
