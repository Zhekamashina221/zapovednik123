# Скопируйте в .env в корне проекта: cp .env.docker.example .env
# backend/.env — секреты и SMTP (см. backend/.env.example)

# Публичный URL сайта (для QR-кодов и писем)
VITE_PUBLIC_SITE_URL=https://ваш-домен.by
APP_PUBLIC_URL=https://ваш-домен.by
CORS_ORIGIN=https://ваш-домен.by

# Порт HTTP на VPS (по умолчанию 80)
HTTP_PORT=80
